---
import { t, type Lang } from '../i18n/translations';
const { lang = 'bs' as Lang } = Astro.props;
const toWebp = (src: string) => src.replace(/\.(jpg|jpeg|JPG)$/, '.webp');
const clients = {
  main: "/images/client-main.jpg",
  others: [
    "/images/client-1.jpg",
    "/images/client-2.jpg",
    "/images/client-3.jpg",
    "/images/client-4.jpg",
    "/images/client-5.JPG",
    "/images/client-6.jpeg",
  ]
};
---

<section id="clients" class="clients-section">
  <div class="clients-bg"></div>

  <div class="container">
    <div class="clients-header">
      <div class="reveal">
        <span class="section-label">{t(lang, 'clients.label')}</span>
        <h2 class="section-title">{t(lang, 'clients.title')} <em>{t(lang, 'clients.titleEm')}</em></h2>
        <div class="rating-bar">
          <div class="stars" aria-label="5 od 5 zvjezdica">
            <svg viewBox="0 0 20 20"><path d="M10 1.5l2.47 5.1 5.63.82-4.07 3.97.96 5.61L10 14.38l-5 2.62.96-5.61L1.9 7.42l5.63-.82L10 1.5z"/></svg>
            <svg viewBox="0 0 20 20"><path d="M10 1.5l2.47 5.1 5.63.82-4.07 3.97.96 5.61L10 14.38l-5 2.62.96-5.61L1.9 7.42l5.63-.82L10 1.5z"/></svg>
            <svg viewBox="0 0 20 20"><path d="M10 1.5l2.47 5.1 5.63.82-4.07 3.97.96 5.61L10 14.38l-5 2.62.96-5.61L1.9 7.42l5.63-.82L10 1.5z"/></svg>
            <svg viewBox="0 0 20 20"><path d="M10 1.5l2.47 5.1 5.63.82-4.07 3.97.96 5.61L10 14.38l-5 2.62.96-5.61L1.9 7.42l5.63-.82L10 1.5z"/></svg>
            <svg viewBox="0 0 20 20"><path d="M10 1.5l2.47 5.1 5.63.82-4.07 3.97.96 5.61L10 14.38l-5 2.62.96-5.61L1.9 7.42l5.63-.82L10 1.5z"/></svg>
          </div>
          <span class="rating-text"><strong>5.0</strong> · {t(lang, 'clients.ratingText')}</span>
        </div>
      </div>
    </div>

    <div class="gallery reveal">
      <!-- HERO IMAGE -->
      <figure class="tile tile-hero">
        <picture>
          <source srcset={toWebp(clients.main)} type="image/webp" />
          <img src={clients.main} alt="Zadovoljni klijent" loading="lazy" />
        </picture>
        <div class="corner tl"></div>
        <div class="corner tr"></div>
        <div class="corner bl"></div>
        <div class="corner br"></div>
        <figcaption class="tile-caption">
          <div class="mini-stars">★★★★★</div>
          <p>{t(lang, 'clients.caption')}</p>
        </figcaption>
      </figure>

      <!-- SMALL TILES -->
      <figure class="tile">
        <picture>
          <source srcset={toWebp(clients.others[0])} type="image/webp" />
          <img src={clients.others[0]} alt="Zadovoljni klijent" loading="lazy" />
        </picture>
        <div class="corner tl"></div><div class="corner tr"></div>
        <div class="corner bl"></div><div class="corner br"></div>
      </figure>

      <figure class="tile">
        <picture>
          <source srcset={toWebp(clients.others[1])} type="image/webp" />
          <img src={clients.others[1]} alt="Zadovoljni klijent" loading="lazy" />
        </picture>
        <div class="corner tl"></div><div class="corner tr"></div>
        <div class="corner bl"></div><div class="corner br"></div>
      </figure>

      <!-- TESTIMONIAL CARD -->
      <figure class="tile tile-testimonial">
        <svg class="quote-mark" viewBox="0 0 40 40" fill="currentColor">
          <path d="M12 10c-4 0-7 3-7 7s3 7 7 7v4c-7 0-13-5-13-13S5 2 12 2v8zm20 0c-4 0-7 3-7 7s3 7 7 7v4c-7 0-13-5-13-13s6-13 13-13v8z"/>
        </svg>
        <blockquote set:html={t(lang, 'clients.testimonial')}>
        </blockquote>
        <div class="testimonial-author">{t(lang, 'clients.testimonialAuthor')}</div>
      </figure>

      <figure class="tile">
        <picture>
          <source srcset={toWebp(clients.others[2])} type="image/webp" />
          <img src={clients.others[2]} alt="Zadovoljni klijent" loading="lazy" />
        </picture>
        <div class="corner tl"></div><div class="corner tr"></div>
        <div class="corner bl"></div><div class="corner br"></div>
      </figure>

      <figure class="tile">
        <picture>
          <source srcset={toWebp(clients.others[3])} type="image/webp" />
          <img src={clients.others[3]} alt="Zadovoljni klijent" loading="lazy" />
        </picture>
        <div class="corner tl"></div><div class="corner tr"></div>
        <div class="corner bl"></div><div class="corner br"></div>
      </figure>

      <figure class="tile">
        <picture>
          <source srcset={toWebp(clients.others[4])} type="image/webp" />
          <img src={clients.others[4]} alt="Zadovoljni klijent" loading="lazy" />
        </picture>
        <div class="corner tl"></div><div class="corner tr"></div>
        <div class="corner bl"></div><div class="corner br"></div>
      </figure>

      <figure class="tile">
        <picture>
          <source srcset={toWebp(clients.others[5])} type="image/webp" />
          <img src={clients.others[5]} alt="Zadovoljni klijent" loading="lazy" />
        </picture>
        <div class="corner tl"></div><div class="corner tr"></div>
        <div class="corner bl"></div><div class="corner br"></div>
      </figure>
    </div>
  </div>
</section>

<style>
  .clients-section {
    padding: 10rem 0;
    background: #000;
    position: relative;
    overflow: hidden;
  }

  .clients-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(201, 169, 110, 0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(201, 169, 110, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 5%;
    position: relative;
    z-index: 1;
  }

  .clients-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .clients-header .section-label {
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-family: var(--serif);
    font-weight: 300;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .section-title em { font-style: italic; color: var(--gold); }

  .rating-bar {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: .7rem 1.4rem;
    border: 1px solid rgba(201, 169, 110, 0.25);
    background: rgba(201, 169, 110, 0.04);
  }

  .stars {
    display: flex;
    gap: .25rem;
    color: var(--gold);
  }

  .stars svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .rating-text {
    font-size: .75rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .rating-text strong {
    color: var(--white);
    font-weight: 500;
    margin-right: .3rem;
  }

  /* GALLERY GRID */
  .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 220px;
    gap: 1.2rem;
  }

  .tile {
    position: relative;
    overflow: hidden;
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.04);
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.4s ease;
    margin: 0;
  }

  .tile-hero {
    grid-row: span 2;
    grid-column: span 1;
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.1s cubic-bezier(0.165, 0.84, 0.44, 1), filter .6s ease;
    filter: saturate(.95) brightness(.95);
  }

  .tile:hover {
    border-color: rgba(201, 169, 110, 0.45);
    transform: translateY(-4px);
  }

  .tile:hover img {
    transform: scale(1.06);
    filter: saturate(1.05) brightness(1);
  }

  /* Gold corner accents */
  .corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: var(--gold);
    opacity: 0;
    transition: opacity .5s ease, inset .5s ease;
    pointer-events: none;
  }

  .corner.tl { top: 10px; left: 10px; border-top: 1px solid; border-left: 1px solid; }
  .corner.tr { top: 10px; right: 10px; border-top: 1px solid; border-right: 1px solid; }
  .corner.bl { bottom: 10px; left: 10px; border-bottom: 1px solid; border-left: 1px solid; }
  .corner.br { bottom: 10px; right: 10px; border-bottom: 1px solid; border-right: 1px solid; }

  .tile:hover .corner { opacity: 1; }

  /* Caption on hero tile */
  .tile-caption {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 2rem 2rem 1.8rem;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.55) 60%, transparent 100%);
    transform: translateY(20%);
    opacity: 0;
    transition: transform .6s ease, opacity .6s ease;
  }

  .tile-hero:hover .tile-caption {
    transform: translateY(0);
    opacity: 1;
  }

  .mini-stars {
    color: var(--gold);
    letter-spacing: .3em;
    font-size: .85rem;
    margin-bottom: .8rem;
  }

  .tile-caption p {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.5;
    color: #fff;
    margin: 0;
  }

  /* Testimonial tile */
  .tile-testimonial {
    background: linear-gradient(145deg, rgba(201, 169, 110, 0.12) 0%, rgba(201, 169, 110, 0.03) 100%);
    border: 1px solid rgba(201, 169, 110, 0.25);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 1.8rem;
    position: relative;
  }

  .tile-testimonial:hover {
    border-color: rgba(201, 169, 110, 0.55);
    transform: translateY(-4px);
  }

  .quote-mark {
    width: 28px;
    height: 28px;
    color: var(--gold);
    opacity: .7;
    margin-bottom: .8rem;
  }

  .tile-testimonial blockquote {
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.55;
    color: #fff;
    margin: 0 0 1rem;
    font-weight: 300;
  }

  .tile-testimonial blockquote em {
    color: var(--gold);
    font-style: italic;
  }

  .testimonial-author {
    font-size: .68rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }
    .tile-hero {
      grid-row: span 2;
      grid-column: span 2;
    }
  }

  @media (max-width: 560px) {
    .clients-header {
      margin-bottom: 3rem;
    }
    .gallery {
      grid-template-columns: 1fr;
      grid-auto-rows: 240px;
      gap: 1rem;
    }
    .tile-hero {
      grid-column: span 1;
      grid-row: span 1;
    }
    .tile-testimonial {
      padding: 1.5rem;
    }
  }
</style>
