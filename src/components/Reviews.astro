---
const reviews = [
  {
    name: "Amina K.",
    date: "januar 2025",
    rating: 5,
    text: "Nevjerovatno iskustvo od prvog pregleda do kraja. Tim je profesionalan, ljubazan i pažljiv. Hollywood Smile je ispao savršeno — iznad svih očekivanja!"
  },
  {
    name: "Mirza H.",
    date: "februar 2025",
    rating: 5,
    text: "Ugradnja implantata bez bola i stresa. Dr. Vuić je objasnio svaki korak zahvata. Rezultat je fantastičan, preporučujem svima bez rezerve."
  },
  {
    name: "Selma B.",
    date: "mart 2025",
    rating: 5,
    text: "Konačno klinika kojoj možete vjerovati. All-on-4 proteza je gotova u jednom danu, a privremeni rad izgleda bolje nego što sam zamislila."
  },
  {
    name: "Edin P.",
    date: "mart 2025",
    rating: 5,
    text: "Moderan prostor, vrhunska oprema i tim koji zaista brine o pacijentima. 3Shape skener bez otisaka — nešto što nisam iskusio nigdje drugdje na Ilidži."
  },
  {
    name: "Lejla M.",
    date: "april 2025",
    rating: 5,
    text: "Odlična klinika! Besplatne konsultacije, transparentne cijene i rezultat koji govori za sebe. Nikad nisam bila sigurnija u vlastiti osmijeh."
  },
  {
    name: "Damir Č.",
    date: "april 2025",
    rating: 5,
    text: "Brzo, bezbolno i profesionalno. Osoblje je uvijek dostupno za sva pitanja. Definitivno ću preporučiti Medea Clinic svim prijateljima i porodici."
  }
];
---

<section id="reviews" class="reviews-section">
  <div class="reviews-bg"></div>
  <div class="container">
    <div class="reviews-header reveal">
      <span class="section-label">Google recenzije</span>
      <div class="reviews-title-row">
        <h2 class="section-title">Šta kažu naši <em>pacijenti</em></h2>
        <div class="google-badge">
          <svg class="google-icon" viewBox="0 0 48 48">
            <path fill="#FFC107" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.9 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 7.9 2.9l5.7-5.7C34.1 6.8 29.3 5 24 5 13 5 4 14 4 25s9 20 20 20 20-9 20-20c0-1.3-.1-2.6-.4-3.9z"/>
            <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.5 16 19 12 24 12c3.1 0 5.8 1.1 7.9 2.9l5.7-5.7C34.1 6.8 29.3 5 24 5c-7.7 0-14.4 4.1-18.1 10.3l.4-.6z" transform="translate(0 1)"/>
            <path fill="#4CAF50" d="M24 45c5.2 0 9.9-1.8 13.6-4.7l-6.3-5.3C29.4 36.6 26.8 37 24 37c-5.2 0-9.6-3.1-11.3-7.6l-6.5 5C9.8 41 16.5 45 24 45z"/>
            <path fill="#1976D2" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.2 5.6l6.3 5.3C37.1 38.8 44 32.5 44 25c0-1.3-.1-2.6-.4-3.9z"/>
          </svg>
          <div class="badge-info">
            <span class="badge-score">5.0</span>
            <div class="badge-stars">★★★★★</div>
            <span class="badge-label">Google ocjena</span>
          </div>
        </div>
      </div>
    </div>

    <div class="swiper reviewsSwiper reveal">
      <div class="swiper-wrapper">
        {reviews.map((review) => (
          <div class="swiper-slide">
            <div class="review-card">
              <div class="review-top">
                <div class="reviewer-avatar">
                  {review.name.charAt(0)}
                </div>
                <div class="reviewer-info">
                  <span class="reviewer-name">{review.name}</span>
                  <span class="reviewer-date">{review.date}</span>
                </div>
                <svg class="google-g" viewBox="0 0 24 24" fill="none">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
              <div class="review-stars">★★★★★</div>
              <p class="review-text">"{review.text}"</p>
              <div class="review-verified">
                <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"><path d="M8 0l2 5.5h5.5l-4.5 3.3 1.7 5.2L8 11 3.3 14 5 8.8.5 5.5H6z"/></svg>
                Potvrđena recenzija
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="swiper-pagination reviews-pagination"></div>
    </div>
  </div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" is:inline></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    new (window as any).Swiper('.reviewsSwiper', {
      slidesPerView: 1,
      spaceBetween: 24,
      loop: true,
      autoplay: {
        delay: 4000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      pagination: {
        el: '.reviews-pagination',
        clickable: true,
      },
      breakpoints: {
        700: { slidesPerView: 2 },
        1100: { slidesPerView: 3 },
      },
      speed: 700,
    });
  });
</script>

<style>
  .reviews-section {
    padding: 10rem 0;
    background: var(--dark);
    position: relative;
    overflow: hidden;
  }

  .reviews-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(201,169,110,.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5%;
    position: relative;
    z-index: 1;
  }

  .reviews-header {
    margin-bottom: 5rem;
  }

  .reviews-header .section-label {
    margin-bottom: 1.2rem;
  }

  .reviews-title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 300;
    color: var(--white);
    margin: 0;
  }

  .section-title em {
    font-style: italic;
    color: var(--gold);
  }

  /* Google badge */
  .google-badge {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border: 1px solid rgba(201,169,110,.2);
    background: rgba(201,169,110,.04);
    flex-shrink: 0;
  }

  .google-icon {
    width: 32px;
    height: 32px;
  }

  .badge-info {
    display: flex;
    flex-direction: column;
    gap: .1rem;
  }

  .badge-score {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--white);
    line-height: 1;
  }

  .badge-stars {
    color: #FFC107;
    font-size: .75rem;
    letter-spacing: .1em;
  }

  .badge-label {
    font-size: .6rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Swiper overrides */
  .reviewsSwiper {
    padding-bottom: 3.5rem !important;
    overflow: hidden;
  }

  .reviews-pagination.swiper-pagination {
    bottom: 0;
  }

  .reviews-pagination .swiper-pagination-bullet {
    background: var(--gold);
    opacity: .3;
    width: 6px;
    height: 6px;
  }

  .reviews-pagination .swiper-pagination-bullet-active {
    opacity: 1;
    width: 20px;
    border-radius: 3px;
    transition: width .4s ease;
  }

  /* Review card */
  .review-card {
    background: var(--dark2);
    border: 1px solid rgba(255,255,255,.04);
    padding: 2.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    transition: border-color .3s ease, transform .3s ease;
    position: relative;
    overflow: hidden;
  }

  .review-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 0; height: 2px;
    background: var(--gold);
    transition: width .5s ease;
  }

  .review-card:hover {
    border-color: rgba(201,169,110,.25);
    transform: translateY(-4px);
  }

  .review-card:hover::before {
    width: 100%;
  }

  .review-top {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .reviewer-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold-dark), var(--gold));
    color: var(--black);
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .reviewer-info {
    display: flex;
    flex-direction: column;
    gap: .2rem;
    flex: 1;
  }

  .reviewer-name {
    font-size: .95rem;
    color: var(--white);
    font-weight: 400;
  }

  .reviewer-date {
    font-size: .7rem;
    letter-spacing: .1em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .google-g {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .review-stars {
    color: #FFC107;
    letter-spacing: .15em;
    font-size: .9rem;
  }

  .review-text {
    font-family: var(--serif);
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(250,250,248,.75);
    flex: 1;
    font-style: italic;
  }

  .review-verified {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-size: .65rem;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,.05);
  }

  .review-verified svg {
    color: var(--gold);
  }

  @media (max-width: 768px) {
    .reviews-title-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
