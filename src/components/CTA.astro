---
<section id="cta">
  <div class="cta-bg"></div>
  <div class="cta-content container">
    <h2 class="cta-title reveal">Spremni za<br><em>novi početak?</em></h2>
    <p class="cta-sub reveal reveal-delay-1">Zakažite termin za besplatne konsultacije već danas</p>
    <div class="cta-actions reveal reveal-delay-2">
      <a href="tel:061828888" class="btn-primary">Pozovite: 061 828 888</a>
      <a href="#contact" class="btn-outline">Pošaljite poruku</a>
    </div>
  </div>
</section>

<style>
  #cta {
    padding: 10rem 0;
    background: var(--dark2);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(201, 169, 110, 0.1) 0%, transparent 70%);
  }

  .cta-content {
    position: relative;
    z-index: 2;
  }

  .cta-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 2rem;
    color: var(--white);
  }

  .cta-title em {
    color: var(--gold);
    font-style: italic;
  }

  .cta-sub {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 4rem;
    letter-spacing: .05em;
  }

  .cta-actions {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 600px) {
    .cta-actions {
      flex-direction: column;
      align-items: center;
    }
    .cta-actions .btn-primary,
    .cta-actions .btn-outline {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
