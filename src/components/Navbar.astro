---
import { t, type Lang } from '../i18n/translations';
const { lang = 'bs' as Lang } = Astro.props;
---
<nav id="navbar" aria-label="Primarna navigacija">
  <div class="nav-container">
    <a href="#hero" class="nav-logo">
      <img src="/images/medea%20logo.png" alt="Medea Clinic Logo" class="logo-img" />
    </a>

    <button class="mobile-menu-toggle" aria-label="Toggle Menu" aria-expanded="false">
      <span></span>
      <span></span>
    </button>

    <ul class="nav-links">
      <li><a href="#about">{t(lang, 'nav.about')}</a></li>
      <li><a href="#services">{t(lang, 'nav.services')}</a></li>
      <li><a href="#team">{t(lang, 'nav.team')}</a></li>
      <li><a href="#contact">{t(lang, 'nav.contact')}</a></li>
      <li class="mobile-only"><a href="#contact" class="nav-cta-mobile">{t(lang, 'nav.cta')}</a></li>
    </ul>

    <a href="#contact" class="nav-cta">{t(lang, 'nav.cta')}</a>

    <div class="lang-switch">
      <span class="lang-divider"></span>
      {([
        { code: 'bs', href: '/', label: 'BS' },
        { code: 'en', href: '/en/', label: 'EN' },
        { code: 'de', href: '/de/', label: 'DE' },
      ] as const)
        .filter(l => l.code !== lang)
        .map((l, i) => (
          <>{i > 0 && <span class="lang-sep">|</span>}<a href={l.href}>{l.label}</a></>
        ))}
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.4rem 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  nav.scrolled {
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    padding: 1rem 0;
    border-bottom: 1px solid rgba(201, 169, 110, 0.1);
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-img {
    height: 45px;
    width: auto;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .nav-logo:hover .logo-img {
    transform: scale(1.05);
  }

  .nav-logo span {
    color: var(--white);
    font-weight: 300;
  }

  .nav-links {
    display: flex;
    gap: 2.2rem;
    list-style: none;
  }

  .nav-links a {
    font-size: .8rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--gold);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-cta {
    font-size: .75rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: .65rem 1.8rem;
    border: 1px solid var(--gold);
    color: var(--gold);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .nav-cta:hover {
    background: var(--gold);
    color: var(--black);
    box-shadow: 0 0 20px rgba(201, 169, 110, 0.2);
  }

  .lang-switch {
    display: flex;
    gap: .4rem;
    align-items: center;
    margin-left: 1.2rem;
  }

  .lang-divider {
    width: 1px;
    height: 18px;
    background: rgba(201, 169, 110, 0.25);
    margin-right: .4rem;
  }

  .lang-sep {
    color: rgba(201, 169, 110, 0.2);
    font-size: .6rem;
    user-select: none;
  }

  .lang-switch a {
    font-size: .7rem;
    font-weight: 500;
    letter-spacing: .12em;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.45);
    transition: all .3s ease;
    padding: .35rem .55rem;
    border: 1px solid transparent;
  }

  .lang-switch a:hover {
    color: var(--gold);
    border-color: rgba(201, 169, 110, 0.25);
  }

  .lang-switch a.active {
    color: var(--gold);
    border-color: rgba(201, 169, 110, 0.4);
    background: rgba(201, 169, 110, 0.08);
  }

  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.7rem;
    min-width: 44px;
    min-height: 44px;
    z-index: 1001;
  }

  .mobile-menu-toggle span {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold);
    margin: 6px 0;
    transition: 0.3s;
  }

  .mobile-menu-toggle.open span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }
  .mobile-menu-toggle.open span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  .mobile-only { display: none; }

  @media (max-width: 900px) {
    .nav-cta,
    .lang-divider {
      display: none;
    }

    .mobile-menu-toggle {
      display: block;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      width: min(80%, 320px);
      background: rgba(10, 10, 10, 0.97);
      backdrop-filter: blur(12px);
      border-left: 1px solid rgba(201, 169, 110, 0.1);
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 4rem 2.5rem;
      gap: 2rem;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-links.open {
      transform: translateX(0);
    }

    .nav-links a {
      font-size: 1rem;
    }

    .mobile-only { display: block; margin-top: 1rem; }

    .nav-cta-mobile {
      display: inline-block;
      padding: .8rem 1.8rem;
      border: 1px solid var(--gold);
      color: var(--gold) !important;
    }
  }
</style>

<script>
  const nav = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  });

  const toggle = document.querySelector('.mobile-menu-toggle');
  const links = document.querySelector('.nav-links');
  toggle?.addEventListener('click', () => {
    const isOpen = links?.classList.toggle('open');
    toggle.classList.toggle('open', !!isOpen);
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });
  links?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      links.classList.remove('open');
      toggle?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>
