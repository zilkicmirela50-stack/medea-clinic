---
import { t, type Lang } from '../i18n/translations';
const { lang = 'bs' as Lang } = Astro.props;
---
<section id="hero">
  <!-- Video background (desktop only) -->
  <video
    class="hero-video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/images/medea%20clinic-hero%20slika.jpg"
    aria-hidden="true"
  >
    <source src="/images/medea%20clinic-hero%20video.mp4" type="video/mp4" />
  </video>
  <!-- Static image fallback (mobile + no-JS) -->
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-grid"></div>

  <div class="hero-content">
    <div class="reveal">
      <span class="hero-tag">{t(lang, 'hero.tag')}</span>
    </div>
    <h1 class="hero-title reveal">
      MEDEA<br><em>CLINIC</em>
    </h1>
    <p class="hero-subtitle reveal reveal-delay-1">
      {t(lang, 'hero.subtitle')}
    </p>
    <div class="hero-actions reveal reveal-delay-2">
      <a href="#contact" class="btn-primary">{t(lang, 'hero.btn1')}</a>
      <a href="#services" class="btn-outline">{t(lang, 'hero.btn2')}</a>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span>{t(lang, 'hero.scroll')}</span>
  </div>
</section>

<style>
  #hero {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    background: var(--black);
  }

  /* Video background */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* Static image fallback — visible on mobile, hidden when video plays on desktop */
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      image-set(
        url('/images/medea%20clinic-hero%20slika.webp') type('image/webp'),
        url('/images/medea%20clinic-hero%20slika.jpg') type('image/jpeg')
      ) center/cover no-repeat;
    z-index: 0;
  }

  /* Dark overlay — sits above video AND image */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.65);
    z-index: 1;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(201,169,110,.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,169,110,.05) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 900px;
    padding: 0 2rem;
  }

  .hero-tag {
    display: inline-block;
    font-size: .7rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2rem;
    padding: .4rem 1.4rem;
    border: 1px solid rgba(201, 169, 110, 0.3);
    background: rgba(201, 169, 110, 0.05);
    backdrop-filter: blur(4px);
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(4rem, 10vw, 8.5rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: .02em;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold);
    display: block;
    margin-top: -0.2rem;
  }

  .hero-subtitle {
    font-family: var(--serif);
    font-size: clamp(1.1rem, 2.5vw, 1.8rem);
    font-weight: 300;
    color: var(--text-muted);
    letter-spacing: .08em;
    margin-bottom: 3.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .8rem;
  }

  .hero-scroll span {
    font-size: .65rem;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    transform-origin: top;
  }

  @keyframes scrollPulse {
    0% { transform: scaleY(0); opacity: 0; }
    50% { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); opacity: 0; transform-origin: bottom; }
  }

  /* Video plays on all screens — hide static bg */
  .hero-bg {
    display: none;
  }

  @media (max-width: 600px) {
    .hero-title {
      font-size: 3.5rem;
    }
    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
      margin: 0 auto;
    }
  }
</style>
