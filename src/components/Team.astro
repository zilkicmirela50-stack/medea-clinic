---
const toWebp = (src: string) => src.replace(/\.(jpg|jpeg|JPG)$/, '.webp');
const team = [
  {
    name: "Dr. Emina Vuić",
    role: "Doktorica dentalne medicine",
    bio: '"Strpljenje, posvećenost i osjećaj za detalje čine temelj svakog njenog rada. Svaki osmijeh koji stvori nosi potpis pažnje i elegancije."',
    img: "/images/emina.jpg"
  },
  {
    name: "Dr. Edis Vuić",
    role: "Doktor dentalne medicine",
    bio: '"Vjeruje da svaki pacijent zaslužuje individualan pristup, vrhunsku estetiku i potpunu udobnost. Savršen osmijeh je naš standard."',
    img: "/images/edis.jpg"
  },
  {
    name: "Dr. Dino Ćenanović",
    role: "Doktor dentalne medicine",
    bio: '"Temelji savremene stomatologije su estetika i preciznost. Individualan pristup i dugoročno oralno zdravlje pacijenta su u fokusu."',
    img: "/images/dino.jpg"
  }
];
---

<section id="team">
  <div class="container">
    <div class="team-header">
      <p class="section-label reveal">Naš tim</p>
      <h2 class="section-title reveal">Upoznajte <em>doktore</em></h2>
      <p class="team-subtitle reveal">Svaki pacijent zaslužuje individualan pristup, vrhunsku estetiku i potpunu udobnost.</p>
    </div>

    <div class="team-grid">
      {team.map((member, index) => (
        <div class={`team-card reveal reveal-delay-${index}`}>
          <div class="image-container">
            <picture>
              <source srcset={toWebp(member.img)} type="image/webp" />
              <img src={member.img} alt={member.name} />
            </picture>
            <div class="image-overlay"></div>
          </div>
          <div class="team-info">
            <h3 class="team-name">{member.name}</h3>
            <p class="team-role">{member.role}</p>
            <div class="team-bio-wrapper">
              <p class="team-bio">{member.bio}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #team {
    padding: 10rem 0;
    background: var(--black);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5%;
  }

  .team-header {
    text-align: center;
    margin-bottom: 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .team-header .section-label {
    justify-content: center;
  }

  .team-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 480px;
    margin-top: 1.5rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(350px, 100%), 1fr));
    gap: 3rem;
  }

  .team-card {
    background: var(--dark2);
    position: relative;
    overflow: hidden;
    transition: transform 0.4s ease;
  }

  .team-card:hover {
    transform: translateY(-10px);
  }

  .image-container {
    position: relative;
    aspect-ratio: 1/1.2;
    overflow: hidden;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .team-card:hover .image-container img {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--black) 0%, transparent 50%);
    opacity: 0.6;
  }

  .team-info {
    padding: 2.5rem;
    text-align: center;
    background: var(--dark2);
    border-top: 1px solid rgba(201, 169, 110, 0.1);
  }

  .team-name {
    font-family: var(--serif);
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .team-role {
    font-size: .75rem;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .team-bio {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.8;
    font-style: italic;
    font-family: var(--serif);
  }

  @media (max-width: 600px) {
    .team-header {
      margin-bottom: 3rem;
    }
    .team-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .team-info {
      padding: 1.8rem;
    }
  }
</style>
